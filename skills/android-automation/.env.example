# android-ai-agent configuration
# Copy this file to .env and fill in your values:
#   cp .env.example .env

# Required: get your free key at https://openrouter.ai/keys
OPENROUTER_API_KEY=your_openrouter_api_key_here

# Optional: override default models
# PLANNER_MODEL=google/gemini-3-flash-preview
# CORTEX_MODEL=google/gemini-3-flash-preview
# SUMMARIZER_MODEL=google/gemini-3.1-flash-lite-preview

# Optional: tuning
# MAX_STEPS=25
# STEP_DELAY=2.0
# LOG_LEVEL=INFO
