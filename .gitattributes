# Force LF line endings for all shell scripts and text files
* text=auto eol=lf
*.sh text eol=lf
*.md text eol=lf
*.json text eol=lf
*.mdx text eol=lf
*.yaml text eol=lf
*.yml text eol=lf
*.toml text eol=lf

# Binary files
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.svg binary
*.zip binary
*.tar.gz binary
